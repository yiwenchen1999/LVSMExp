# Explorer SSH tunnel defaults. Override via environment, e.g.:
#   SBATCH_TIME=12:00:00 bash bash_scripts/cluster-tunnel/tunnel.sh submit

SSH_LOGIN_HOST="${SSH_LOGIN_HOST:-explorer}"
SSH_TUNNEL_HOST="${SSH_TUNNEL_HOST:-explorer_tunnel}"

TUNNEL_JOB_NAME="${TUNNEL_JOB_NAME:-tunnel}"
TUNNEL_PORT="${TUNNEL_PORT:-2222}"
TUNNEL_HOST_KEY="${TUNNEL_HOST_KEY:-\$HOME/.ssh/tunnel_host_key}"

REMOTE_TUNNEL_DIR="${REMOTE_TUNNEL_DIR:-cluster-tunnel}"
LOCAL_IDENTITY_FILE="${LOCAL_IDENTITY_FILE:-\$HOME/.ssh/id_rsa.pub}"

SBATCH_PARTITION="${SBATCH_PARTITION:-jiang}"
SBATCH_GRES="${SBATCH_GRES:-gpu:a6000:1}"
SBATCH_MEM="${SBATCH_MEM:-32G}"
SBATCH_TIME="${SBATCH_TIME:-8:00:00}"
SBATCH_NTASKS="${SBATCH_NTASKS:-8}"
SBATCH_NODES="${SBATCH_NODES:-1}"

CONNECT_WAIT_SECS="${CONNECT_WAIT_SECS:-600}"
CONNECT_POLL_SECS="${CONNECT_POLL_SECS:-5}"
